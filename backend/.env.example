# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=linvnix

# Application
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Legacy support (deprecated, use JWT_ACCESS_EXPIRES_IN instead)
JWT_EXPIRES_IN=15m

# API
API_PREFIX=api
API_VERSION=v1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Storage
BASE_URL=http://localhost:3000

# Mail Configuration (Gmail)
# Để sử dụng Gmail, bạn cần:
# 1. Bật 2-Step Verification trong Google Account
# 2. Tạo App Password tại: https://myaccount.google.com/apppasswords
# 3. Sử dụng App Password thay vì password thật
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password
MAIL_FROM_NAME=Language Learning App
MAIL_FROM_ADDRESS=your-email@gmail.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3001

# Google OAuth
# Tạo OAuth credentials tại: https://console.cloud.google.com/apis/credentials
# 1. Tạo OAuth 2.0 Client ID
# 2. Thêm Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Google GenAI (Gemini)
GEMINI_API_KEY=your-gemini-api-key
GENAI_API_KEYS=key1,key2,key3
GENAI_CHAT_MODEL=gemini-2.5-flash
GENAI_CHAT_FALLBACK_MODEL=gemini-2.0-flash
GENAI_EMBED_MODEL=text-embedding-004
GENAI_IMAGE_MODEL=imagen-4.0-generate-001
GENAI_TTS_MODEL=gemini-2.5-flash-preview-tts
GENAI_MAX_RETRIES=2
GENAI_TIMEOUT=30000
