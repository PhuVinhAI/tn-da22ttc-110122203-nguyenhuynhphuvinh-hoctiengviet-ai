---
import { Icon } from 'astro-icon/components';
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import { defaultLang, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const items = [
	{ q: t('faq.q1'), a: t('faq.a1') },
	{ q: t('faq.q2'), a: t('faq.a2') },
	{ q: t('faq.q3'), a: t('faq.a3') },
	{ q: t('faq.q4'), a: t('faq.a4') },
	{ q: t('faq.q5'), a: t('faq.a5') },
];
---

<Section id="faq" bordered>
	<Container size="md">
		<div class="text-center mb-12 space-y-4">
			<div class="text-sm font-medium text-primary">{t('faq.eyebrow')}</div>
			<h2 class="text-4xl md:text-5xl font-bold tracking-tight">
				{t('faq.title')}
			</h2>
		</div>

		<div class="rounded-2xl border border-border overflow-hidden divide-y divide-border bg-background">
			{
				items.map((item, i) => (
					<details class="group" open={i === 0}>
						<summary class="flex items-center justify-between cursor-pointer list-none px-6 py-5 hover:bg-muted/50 transition-colors">
							<span class="text-base font-medium pr-6">{item.q}</span>
							<Icon
								name="lucide:plus"
								class="size-5 text-muted-foreground shrink-0 transition-transform group-open:rotate-45"
							/>
						</summary>
						<div class="px-6 pb-5 text-sm text-muted-foreground leading-relaxed">
							{item.a}
						</div>
					</details>
				))
			}
		</div>
	</Container>
</Section>
