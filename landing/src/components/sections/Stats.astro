---
import Container from '../ui/Container.astro';
import { defaultLang, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const stats = [
	{
		idx: '01',
		value: 500,
		suffix: '+',
		isCount: true,
		label: t('stats.lessons'),
		note: t('stats.lessonsNote'),
		span: 'md:col-span-4',
	},
	{
		idx: '02',
		value: null,
		text: 'A1–C2',
		label: t('stats.levels'),
		note: t('stats.levelsNote'),
		span: 'md:col-span-4',
	},
	{
		idx: '03',
		value: 9,
		suffix: '',
		isCount: true,
		label: t('stats.languages'),
		note: t('stats.languagesNote'),
		span: 'md:col-span-2',
	},
	{
		idx: '04',
		value: 4,
		suffix: '',
		isCount: true,
		label: t('stats.dialects'),
		note: t('stats.dialectsNote'),
		span: 'md:col-span-2',
	},
];
---

<section class="border-b border-border bg-card relative">
	<Container size="xl">
		<div
			class="py-10 sm:py-14 md:py-20 grid md:grid-cols-12 gap-x-6 gap-y-10 sm:gap-y-12 md:gap-y-0 divide-y md:divide-y-0 divide-border"
		>
			{
				stats.map((s, i) => (
					<article
						class={`${s.span} ${i > 0 ? 'md:border-l md:border-border md:pl-6' : ''} pt-10 sm:pt-12 md:pt-0`}
						data-reveal="up"
						data-reveal-delay={`${i * 0.08}`}
					>
						<div class="flex items-baseline justify-between mb-5 sm:mb-6 md:mb-10">
							<span class="text-[10px] uppercase tracking-[0.3em] text-muted-foreground num-tabular">
								{s.idx}
							</span>
							<span class="text-[10px] uppercase tracking-[0.3em] text-muted-foreground">
								/ stat
							</span>
						</div>

						<div class="font-bold tracking-tight num-tabular leading-none">
							{s.isCount ? (
								<span class="block text-5xl sm:text-6xl md:text-7xl lg:text-8xl whitespace-nowrap">
									<span
										data-count={s.value}
										data-count-suffix={s.suffix}
									>
										0{s.suffix}
									</span>
								</span>
							) : (
								<span class="block text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-primary whitespace-nowrap">
									{s.text}
								</span>
							)}
						</div>

						<!-- Hand-drawn underline -->
						<svg
							viewBox="0 0 200 10"
							class="mt-6 md:mt-8 w-full h-2 text-primary"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							data-draw
							data-draw-duration="1.6"
						>
							<path d="M2 5 Q 50 1, 100 5 T 198 5" stroke-linecap="round" />
						</svg>

						<div class="mt-6 md:mt-8 text-sm md:text-base font-semibold text-foreground">
							{s.label}
						</div>
						<div class="mt-1 text-xs text-muted-foreground">
							{s.note}
						</div>
					</article>
				))
			}
		</div>
	</Container>
</section>
