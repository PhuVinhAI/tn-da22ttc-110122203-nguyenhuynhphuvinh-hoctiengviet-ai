---
import { Icon } from 'astro-icon/components';
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Mark from '../art/Mark.astro';
import OrbitDecor from '../art/OrbitDecor.astro';
import { defaultLang, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';
import { DEMO_APK_URL, DEMO_APK_FILENAME, CONTACT_URL } from '../../config';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<Section id="cta" class="bg-foreground text-background relative overflow-hidden">
	<!-- Rotating decorative orbit -->
	<div
		aria-hidden="true"
		class="hidden sm:block absolute -right-40 -top-32 size-[42rem] text-background/15 pointer-events-none"
		data-rotate-on-scroll="180"
	>
		<OrbitDecor class="size-full" />
	</div>

	<!-- Floating decorative marks (md+ only to avoid clutter on phones) -->
	<div
		aria-hidden="true"
		class="hidden md:block absolute left-[10%] top-[20%] size-12 text-primary"
		data-float
		data-float-duration="5"
	>
		<Mark type="acute" class="size-full" />
	</div>
	<div
		aria-hidden="true"
		class="hidden md:block absolute right-[8%] bottom-[28%] size-9 text-background/30"
		data-float
		data-float-duration="6"
	>
		<Mark type="grave" class="size-full" />
	</div>

	<Container size="xl">
		<div class="relative py-8 md:py-16">
			<!-- top meta -->
			<div
				class="text-[10px] uppercase tracking-[0.3em] text-background/60 num-tabular"
				data-reveal="up"
			>
				/ ready — chapter 06
			</div>

			<!-- Full-width title -->
			<h2 class="mt-8 md:mt-12 text-hero leading-[0.95] font-bold max-w-[14ch]">
				<span class="block" data-split="word">{t('cta.title')}</span>
			</h2>

			<!-- Subtitle + CTAs row -->
			<div class="mt-10 sm:mt-12 md:mt-20 grid md:grid-cols-12 gap-6 sm:gap-8 md:gap-12 items-end">
				<p
					class="md:col-span-6 lg:col-span-5 text-base md:text-lg text-background/75 leading-[1.6] max-w-md"
					data-reveal="up"
					data-reveal-delay="0.1"
				>
					{t('cta.subtitle')}
				</p>
				<div
					class="md:col-span-6 lg:col-span-7 flex flex-col sm:flex-row items-stretch sm:items-center md:justify-end gap-3"
					data-reveal="up"
					data-reveal-delay="0.2"
				>
					<div data-magnet="0.3">
						<a
							href={DEMO_APK_URL}
							download={DEMO_APK_FILENAME}
							data-magnet-inner
							class="group inline-flex items-center justify-between gap-3 h-14 px-7 rounded-full bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity"
						>
							<span>{t('cta.primary')}</span>
							<Icon name="lucide:arrow-down-to-line" class="size-4" />
						</a>
					</div>
					<a
						href={CONTACT_URL}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-between gap-3 h-14 px-7 rounded-full border border-background/30 hover:bg-background/10 transition-colors font-semibold"
					>
						<span>{t('cta.secondary')}</span>
						<Icon name="lucide:arrow-up-right" class="size-4" />
					</a>
				</div>
			</div>
		</div>

		<!-- credits strip -->
		<div
			class="mt-8 md:mt-12 pt-8 border-t border-background/20 grid md:grid-cols-12 gap-6 items-center text-[10px] uppercase tracking-[0.3em] text-background/60 num-tabular"
		>
			<div class="md:col-span-4 flex items-center gap-3">
				<span class="size-1.5 rounded-full bg-primary animate-pulse"></span>
				<span data-scribble>LinVNix · 2026</span>
			</div>
			<div class="md:col-span-4 md:text-center">Vol. 01 / Edition 1</div>
			<div class="md:col-span-4 md:text-right">Android APK · iOS soon · Web soon</div>
		</div>
	</Container>
</Section>
