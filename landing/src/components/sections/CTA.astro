---
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import { defaultLang, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';
import { DEMO_APK_URL, DEMO_APK_FILENAME } from '../../config';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<Section id="cta">
	<Container size="md">
		<div class="rounded-2xl border border-border bg-muted p-12 md:p-16 text-center space-y-6">
			<h2 class="text-3xl md:text-4xl font-bold tracking-tight">
				{t('cta.title')}
			</h2>
			<p class="text-lg text-muted-foreground max-w-xl mx-auto">
				{t('cta.subtitle')}
			</p>
			<div class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-2">
				<Button
					href={DEMO_APK_URL}
					download={DEMO_APK_FILENAME}
					variant="primary"
					size="lg"
				>
					{t('cta.primary')}
				</Button>
				<Button href="/contact" variant="outline" size="lg">{t('cta.secondary')}</Button>
			</div>
		</div>
	</Container>
</Section>
