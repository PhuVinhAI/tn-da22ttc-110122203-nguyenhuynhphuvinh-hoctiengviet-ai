---
import { Icon } from 'astro-icon/components';
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import { defaultLang, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const testimonials = [
	{ quote: t('test.q1'), name: t('test.n1'), role: t('test.r1') },
	{ quote: t('test.q2'), name: t('test.n2'), role: t('test.r2') },
	{ quote: t('test.q3'), name: t('test.n3'), role: t('test.r3') },
];
---

<Section id="testimonials" bordered>
	<Container size="xl">
		<div class="text-center mb-16 space-y-4">
			<div class="text-sm font-medium text-primary">{t('test.eyebrow')}</div>
			<h2 class="text-4xl md:text-5xl font-bold tracking-tight">
				{t('test.title')}
			</h2>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			{
				testimonials.map((testimonial) => (
					<figure class="rounded-2xl border border-border bg-background p-8 flex flex-col">
						<Icon name="lucide:quote" class="size-6 text-primary" />
						<blockquote class="mt-4 text-base leading-relaxed text-foreground/90 flex-1">
							“{testimonial.quote}”
						</blockquote>
						<figcaption class="mt-6 pt-6 border-t border-border">
							<div class="text-sm font-semibold">{testimonial.name}</div>
							<div class="text-sm text-muted-foreground">{testimonial.role}</div>
						</figcaption>
					</figure>
				))
			}
		</div>
	</Container>
</Section>
