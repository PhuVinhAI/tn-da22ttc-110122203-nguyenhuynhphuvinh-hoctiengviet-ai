---
import { Icon } from 'astro-icon/components';
import Container from '../ui/Container.astro';
import Section from '../ui/Section.astro';
import Mark from '../art/Mark.astro';
import { defaultLang, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';
import { DEMO_APK_URL, DEMO_APK_FILENAME } from '../../config';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const features = [
	t('pricing.demoF1'),
	t('pricing.demoF2'),
	t('pricing.demoF3'),
	t('pricing.demoF4'),
	t('pricing.demoF5'),
	t('pricing.demoF6'),
];
---

<Section id="pricing" bordered class="bg-muted/50 relative">
	<Container size="xl">
		<!-- editorial header -->
		<div class="grid md:grid-cols-12 gap-6 sm:gap-8 mb-10 sm:mb-12 md:mb-20 items-end">
			<div class="md:col-span-7" data-reveal="up">
				<div class="text-[10px] uppercase tracking-[0.3em] text-muted-foreground">
					/ {t('pricing.eyebrow')} — chapter 04
				</div>
				<h2 class="mt-6 text-section font-bold">
					<span class="block" data-split="word">{t('pricing.title')}</span>
				</h2>
			</div>
			<div class="md:col-span-4 md:col-start-9" data-reveal="up" data-reveal-delay="0.1">
				<p class="text-base md:text-lg text-foreground/75 leading-[1.55]">
					{t('pricing.subtitle')}
				</p>
			</div>
		</div>

		<!-- Pricing card -->
		<div
			class="grid md:grid-cols-12 rounded-3xl border border-border bg-background overflow-hidden relative"
			data-reveal="up"
		>
			<!-- LEFT: price block -->
			<div
				class="md:col-span-5 p-6 sm:p-8 md:p-12 lg:p-14 border-b md:border-b-0 md:border-r border-border bg-foreground text-background flex flex-col relative overflow-hidden"
			>
				<!-- watermark -->
				<div aria-hidden="true" class="absolute -top-6 -right-6 size-44 text-background/10" data-float>
					<Mark type="tilde" class="size-full" />
				</div>

				<!-- demo badge -->
				<div
					class="inline-flex self-start items-center gap-2 rounded-full border border-background/40 px-3.5 py-1.5 text-[10px] uppercase tracking-[0.25em]"
				>
					<span class="size-1 rounded-full bg-background animate-pulse"></span>
					{t('pricing.demoBadge')}
				</div>

				<div class="mt-auto pt-12 sm:pt-16 md:pt-20">
					<div class="text-xs uppercase tracking-[0.25em] text-background/60">
						{t('pricing.demoName')}
					</div>
					<div class="mt-4 sm:mt-6 flex items-baseline gap-3 flex-wrap">
						<span class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-bold tracking-tight leading-none break-words">
							{t('pricing.demoPrice')}
						</span>
						<span class="size-3 rounded-full bg-primary translate-y-[-0.5rem]"></span>
					</div>
					<p class="mt-4 sm:mt-6 text-sm text-background/70 max-w-sm leading-[1.6]">
						{t('pricing.demoDesc')}
					</p>
				</div>
			</div>

			<!-- RIGHT: details -->
			<div class="md:col-span-7 p-6 sm:p-8 md:p-12 lg:p-14 flex flex-col">
				<div class="flex items-center gap-3 text-[10px] uppercase tracking-[0.3em] text-muted-foreground">
					<span>included</span>
					<div class="h-px flex-1 bg-border"></div>
					<span class="num-tabular">06 / 06</span>
				</div>

				<ul class="mt-8 grid sm:grid-cols-2 gap-x-8 gap-y-1" data-stagger>
					{
						features.map((f, i) => (
							<li class="group flex items-start gap-4 text-sm border-b border-border py-4">
								<span class="text-[10px] uppercase tracking-[0.25em] text-muted-foreground pt-1 shrink-0 num-tabular">
									{String(i + 1).padStart(2, '0')}
								</span>
								<span class="text-foreground/90 leading-snug flex-1">
									{f}
								</span>
								<Icon
									name="lucide:check"
									class="size-4 mt-1 text-primary shrink-0"
								/>
							</li>
						))
					}
				</ul>

				<div class="mt-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
					<p class="text-xs text-muted-foreground max-w-xs leading-[1.5]">
						{t('pricing.demoNote')}
					</p>
					<div data-magnet="0.3">
						<a
							href={DEMO_APK_URL}
							download={DEMO_APK_FILENAME}
							data-magnet-inner
							class="inline-flex items-center gap-3 h-14 px-7 rounded-full bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity"
						>
							<Icon name="lucide:download" class="size-4" />
							<span>{t('pricing.demoCta')}</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</Container>
</Section>
