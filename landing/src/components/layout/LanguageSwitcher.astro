---
import { Icon } from 'astro-icon/components';
import { languages, localeOrder, type Lang } from '../../i18n/config';
import { localizedPath } from '../../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const current = languages[lang];
---

<div class="relative group">
	<button
		type="button"
		class="inline-flex items-center gap-1.5 h-9 px-3 rounded-lg border border-border bg-background text-sm font-medium hover:bg-muted transition-colors"
		aria-haspopup="true"
	>
		<Icon name="lucide:globe" class="size-4 text-muted-foreground" />
		<span>{current}</span>
		<Icon name="lucide:chevron-down" class="size-3.5 text-muted-foreground" />
	</button>

	<div
		class="absolute right-0 mt-2 w-44 rounded-lg border border-border bg-background opacity-0 invisible group-hover:opacity-100 group-hover:visible focus-within:opacity-100 focus-within:visible transition py-1.5"
		role="menu"
	>
		{
			localeOrder.map((code) => (
				<a
					href={localizedPath(code)}
					class={`block px-3.5 py-2 text-sm hover:bg-muted ${
						code === lang ? 'text-primary font-medium' : 'text-foreground'
					}`}
					hreflang={code}
				>
					{languages[code]}
				</a>
			))
		}
	</div>
</div>
