---
import { Icon } from 'astro-icon/components';
import Logo from '../ui/Logo.astro';
import { LanguageSwitcher } from './LanguageSwitcher.tsx';
import { ThemeToggle } from './ThemeToggle.tsx';
import { type Lang, defaultLang, languages, localeOrder } from '../../i18n/config';
import { localizedPath, useTranslations } from '../../i18n/utils';
import { DEMO_APK_URL, DEMO_APK_FILENAME } from '../../config';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const base = localizedPath(lang);

const navItems = [
	{ label: t('nav.features'), href: `${base}#features` },
	{ label: t('nav.howItWorks'), href: `${base}#how-it-works` },
	{ label: t('nav.pricing'), href: `${base}#pricing` },
	{ label: t('nav.faq'), href: `${base}#faq` },
];

const langOptions = localeOrder.map((code) => ({ code, label: languages[code] }));
const langHrefs = Object.fromEntries(localeOrder.map((code) => [code, localizedPath(code)]));
---

<header class="fixed top-3 md:top-6 inset-x-0 z-50 flex justify-center px-3 sm:px-4 pointer-events-none">
	<div
		class="pointer-events-auto inline-flex items-center gap-1 md:gap-2 rounded-full border border-border bg-background/75 backdrop-blur-xl pl-2.5 pr-1.5 md:pl-5 md:pr-2 py-1.5 md:py-2 max-w-[calc(100vw-1.5rem)]"
		data-reveal="down"
		data-reveal-trigger="load"
	>
		<Logo href={base} size="sm" />

		<nav class="hidden lg:flex items-center gap-1 ml-3 pl-4 border-l border-border h-7">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class="link-editorial relative text-xs font-mono uppercase tracking-[0.15em] text-muted-foreground hover:text-foreground transition-colors px-3 py-1.5"
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<div class="flex items-center gap-1 ml-1 md:ml-2">
			<ThemeToggle
				client:idle
				labels={{ light: t('theme.light'), dark: t('theme.dark') }}
			/>
			<LanguageSwitcher
				client:idle
				current={lang}
				currentLabel={languages[lang]}
				options={langOptions}
				hrefs={langHrefs}
			/>
			<a
				href={DEMO_APK_URL}
				download={DEMO_APK_FILENAME}
				class="inline-flex items-center gap-1.5 h-9 px-3 md:px-4 rounded-full bg-primary text-primary-foreground text-xs font-mono uppercase tracking-[0.15em] hover:opacity-90 transition-opacity"
			>
				<Icon name="lucide:arrow-down-to-line" class="size-3.5" />
				<span class="hidden sm:inline">{t('nav.getStarted')}</span>
			</a>
		</div>
	</div>
</header>
