---
interface Props {
	class?: string;
	size?: 'sm' | 'md' | 'lg' | 'xl';
}

const { class: className = '', size = 'lg' } = Astro.props;

const sizes = {
	sm: 'max-w-3xl',
	md: 'max-w-5xl',
	lg: 'max-w-6xl',
	xl: 'max-w-7xl',
};
---

<div class={`mx-auto w-full px-5 sm:px-6 md:px-10 ${sizes[size]} ${className}`}>
	<slot />
</div>
