---
interface Props {
	href?: string;
	size?: 'sm' | 'md' | 'lg';
	withText?: boolean;
	class?: string;
}

const {
	href,
	size = 'md',
	withText = true,
	class: className = '',
} = Astro.props;

const iconSizes = {
	sm: 'size-6',
	md: 'size-7',
	lg: 'size-10',
};

const textSizes = {
	sm: 'text-base',
	md: 'text-lg',
	lg: 'text-2xl',
};

const Tag = href ? 'a' : 'div';
---

<Tag href={href} class={`inline-flex items-center gap-2 ${className}`}>
	<img
		src="/icon.svg"
		alt="LinVNix"
		width="40"
		height="40"
		class={iconSizes[size]}
	/>
	{withText && (
		<span class={`font-bold tracking-tight ${textSizes[size]}`}>LinVNix</span>
	)}
</Tag>
