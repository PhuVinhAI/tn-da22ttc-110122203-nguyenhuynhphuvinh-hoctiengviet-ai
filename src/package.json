{
  "name": "linvnix",
  "version": "1.0.0",
  "description": "LinVNix Monorepo - Admin (Electron+Web), NestJS Backend, Astro Landing, Flutter Mobile, shared packages",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "admin",
    "backend",
    "landing",
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres",
    "backend:dev": "bun --filter backend start:dev",
    "backend:build": "bun --filter backend build",
    "backend:start": "bun --filter backend start:prod",
    "admin:dev": "bun --filter linvnix-admin dev",
    "admin:dev:web": "bun --filter linvnix-admin dev:web",
    "admin:build:web": "bun --filter linvnix-admin build:web",
    "admin:build:win": "bun --filter linvnix-admin build:win",
    "admin:build:mac": "bun --filter linvnix-admin build:mac",
    "admin:build:linux": "bun --filter linvnix-admin build:linux",
    "landing:dev": "bun --filter landing dev",
    "landing:build": "bun --filter landing build",
    "landing:preview": "bun --filter landing preview",
    "shared:build": "bun --filter @linvnix/shared build",
    "mobile:run": "cd mobile && flutter run",
    "mobile:build:android": "cd mobile && flutter build apk",
    "mobile:build:ios": "cd mobile && flutter build ios",
    "mobile:pub:get": "cd mobile && flutter pub get",
    "mobile:test": "cd mobile && flutter test",
    "mobile:ip": "node update-ip.js",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "bun --filter '*' lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PhuVinhAI/LinVNix.git"
  },
  "keywords": ["monorepo", "nestjs", "flutter", "bun"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
