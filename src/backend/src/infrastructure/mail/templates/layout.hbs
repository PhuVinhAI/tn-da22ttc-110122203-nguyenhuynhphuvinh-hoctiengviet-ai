<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>{{appName}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #FAFAF9;
      font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
      color: #18181B;
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
    }
    .wrapper {
      width: 100%;
      background-color: #FAFAF9;
      padding: 40px 16px;
    }
    .container {
      max-width: 520px;
      margin: 0 auto;
    }
    .brand-card {
      background: #FFFFFF;
      border: 1px solid #E4E4E7;
      border-radius: 14px;
      padding: 28px 24px 24px;
      text-align: center;
      margin-bottom: 12px;
    }
    .brand-icon {
      display: inline-block;
      width: 72px;
      height: 72px;
      line-height: 72px;
      background-color: rgba(99, 102, 241, 0.1);
      border: 1px solid #E4E4E7;
      border-radius: 20px;
      font-size: 28px;
      font-weight: 700;
      color: #6366F1;
      margin-bottom: 16px;
    }
    .brand-name {
      margin: 0;
      font-size: 34px;
      font-weight: 700;
      letter-spacing: -1px;
      color: #18181B;
    }
    .brand-tagline {
      margin: 6px 0 0;
      font-size: 17px;
      color: #71717A;
    }
    .content-card {
      background: #FFFFFF;
      border: 1px solid #E4E4E7;
      border-radius: 14px;
      padding: 28px 24px;
    }
    .content-card h1 {
      margin: 0 0 12px;
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.3px;
      color: #18181B;
    }
    .content-card h2 {
      margin: 0 0 8px;
      font-size: 15px;
      font-weight: 600;
      color: #18181B;
    }
    .content-card p {
      margin: 0 0 14px;
      font-size: 15px;
      color: #3F3F46;
    }
    .content-card p:last-child {
      margin-bottom: 0;
    }
    .muted {
      color: #71717A;
      font-size: 14px;
    }
    .label {
      display: block;
      margin-bottom: 8px;
      font-size: 13px;
      font-weight: 500;
      color: #71717A;
    }
    .code-box {
      display: block;
      margin: 0 auto 12px;
      max-width: 280px;
      padding: 18px 20px;
      background: #FFFFFF;
      border: 1px solid #D4D4D8;
      border-radius: 10px;
      font-size: 32px;
      font-weight: 700;
      letter-spacing: 10px;
      text-align: center;
      color: #6366F1;
    }
    .chip-row {
      margin: 16px 0 0;
      padding: 0;
      list-style: none;
    }
    .chip-row li {
      margin: 0 0 8px;
      padding: 12px 14px;
      background: #F4F4F5;
      border: 1px solid #E4E4E7;
      border-radius: 10px;
      font-size: 14px;
      color: #3F3F46;
    }
    .surface {
      margin-top: 16px;
      padding: 14px 16px;
      border: 1px solid #E4E4E7;
      border-radius: 10px;
      font-size: 14px;
      color: #3F3F46;
    }
    .surface p {
      margin: 0 0 8px;
      font-size: 14px;
      color: #3F3F46;
    }
    .surface p:last-child {
      margin-bottom: 0;
    }
    .surface-muted {
      background: #F4F4F5;
    }
    .surface-primary {
      background: rgba(99, 102, 241, 0.08);
      border-color: #C7D2FE;
      color: #4338CA;
    }
    .surface-success {
      background: #F0FDF4;
      border-color: #BBF7D0;
      color: #166534;
    }
    .surface-warning {
      background: #FFFBEB;
      border-color: #FDE68A;
      color: #92400E;
    }
    .surface-error {
      background: #FEF2F2;
      border-color: #FECACA;
      color: #991B1B;
    }
    .surface ul {
      margin: 8px 0 0;
      padding-left: 18px;
    }
    .surface li {
      margin-bottom: 4px;
    }
    .action-card {
      margin-top: 20px;
      padding: 16px;
      text-align: center;
      background: #F4F4F5;
      border: 1px solid #E4E4E7;
      border-radius: 10px;
    }
    .action-card strong {
      display: block;
      margin-bottom: 4px;
      font-size: 15px;
      font-weight: 600;
      color: #18181B;
    }
    .divider {
      height: 1px;
      margin: 20px 0;
      background: #E4E4E7;
      border: none;
    }
    .footer {
      margin-top: 20px;
      text-align: center;
      font-size: 12px;
      color: #71717A;
      line-height: 1.5;
    }
    .footer a {
      color: #6366F1;
      text-decoration: none;
      font-weight: 500;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="container">
      <div class="brand-card">
        <div class="brand-icon">VN</div>
        <p class="brand-name">{{appName}}</p>
        <p class="brand-tagline">{{tagline}}</p>
      </div>
      <div class="content-card">
        {{{body}}}
      </div>
      <div class="footer">
        <p>&copy; {{year}} {{appName}}. All rights reserved.</p>
        {{#if supportEmail}}
        <p>Need help? <a href="mailto:{{supportEmail}}">{{supportEmail}}</a></p>
        {{/if}}
        <p>This is an automated message. Please do not reply directly.</p>
      </div>
    </div>
  </div>
</body>
</html>
