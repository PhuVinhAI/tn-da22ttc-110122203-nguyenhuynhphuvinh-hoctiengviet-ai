  "scripts": {
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration:bookmarks": "bun run scripts/test/suites/bookmarks.test.ts",
    "test:integration:search-vocabulary": "bun run scripts/test/suites/search-vocabulary.test.ts",
    "test:integration:simulations-seed": "bun run scripts/test/suites/simulations-seed.test.ts",
    "test:integration:personal-vocabularies": "bun run scripts/test/suites/personal-vocabularies.test.ts",
    "admin:create": "bun run scripts/create-admin.ts",
    "db:reset-seed": "bun run scripts/reset-and-seed.ts",
    "seed:lessons": "bun run scripts/seed-lessons.ts",
    "seed:simulations": "bun run scripts/seed-simulations.ts",
    "seed:simulations:direct": "bun run scripts/seed-simulations-direct.ts",
    "generate:user-seeds": "bun run scripts/generate-user-seeds.ts",
    "seed:users": "bun run scripts/seed-users.ts"
  },
  "dependencies": {
    "@google/genai": "^2.0.1",
