---
interface Props {
	href?: string;
	size?: 'sm' | 'md' | 'lg';
	withText?: boolean;
	class?: string;
}

const {
	href,
	size = 'md',
	withText = true,
	class: className = '',
} = Astro.props;

const iconSizes = {
	sm: 'size-6',
	md: 'size-7',
	lg: 'size-10',
};

const textSizes = {
	sm: 'text-base',
	md: 'text-lg',
	lg: 'text-2xl',
};

const Tag = href ? 'a' : 'div';
const base = import.meta.env.BASE_URL;
---

<Tag href={href} class={`inline-flex items-center gap-2.5 group ${className}`}>
	<img
		src={`${base}icon.png`}
		alt="LinVNix"
		width="40"
		height="40"
		class={`${iconSizes[size]} rounded-lg select-none transition-transform duration-500 group-hover:rotate-[-6deg]`}
		draggable="false"
	/>
	{withText && (
		<span class={`font-bold tracking-tight ${textSizes[size]}`}>
			Lin<span class="text-primary">V</span>Nix
		</span>
	)}
</Tag>
