---
import { Icon } from 'astro-icon/components';
import Container from '../ui/Container.astro';
import LevelPicker from '../art/LevelPicker.astro';
import WovenLesson from '../art/WovenLesson.astro';
import StreakFlame from '../art/StreakFlame.astro';
import { defaultLang, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const steps = [
	{
		n: '01',
		eyebrow: 'PLACEMENT',
		title: t('how.s1Title'),
		desc: t('how.s1Desc'),
		art: 'picker',
	},
	{
		n: '02',
		eyebrow: 'STUDY',
		title: t('how.s2Title'),
		desc: t('how.s2Desc'),
		art: 'woven',
	},
	{
		n: '03',
		eyebrow: 'STREAK',
		title: t('how.s3Title'),
		desc: t('how.s3Desc'),
		art: 'streak',
	},
];
---

<section
	id="how-it-works"
	data-horizontal
	class="relative md:h-[100vh] overflow-hidden border-b border-border bg-background"
>
	<div data-horizontal-track class="flex flex-col md:flex-row md:h-full md:w-max">
		<!-- Intro panel -->
		<div
			class="w-full md:w-screen md:h-full flex flex-col justify-center border-b md:border-b-0 md:border-r border-border bg-muted/50 relative"
		>
			<!-- corner ticks -->
			<div aria-hidden="true" class="absolute top-8 left-8 size-12 text-border">
				<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1" data-draw>
					<line x1="2" y1="2" x2="20" y2="2" />
					<line x1="2" y1="2" x2="2" y2="20" />
				</svg>
			</div>
			<div aria-hidden="true" class="absolute bottom-8 right-8 size-12 text-border">
				<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1" data-draw>
					<line x1="28" y1="46" x2="46" y2="46" />
					<line x1="46" y1="28" x2="46" y2="46" />
				</svg>
			</div>

			<Container size="xl" class="py-14 sm:py-20 md:py-0">
				<div class="grid md:grid-cols-12 gap-6 sm:gap-8 md:gap-16 items-end">
					<div class="md:col-span-7 space-y-8">
						<div class="text-[10px] uppercase tracking-[0.3em] text-muted-foreground">
							/ {t('how.eyebrow')} — chapter 02
						</div>
						<h2 class="text-section font-bold">
							<span class="block" data-split="word">
								{t('how.title')}
							</span>
						</h2>
					</div>
					<div class="md:col-span-5 md:pl-8 md:border-l md:border-border space-y-6">
						<p class="text-base md:text-lg text-foreground/75 leading-[1.55]" data-reveal="up">
							{t('how.subtitle')}
						</p>
						<div
							class="hidden md:flex items-center gap-3 text-[10px] uppercase tracking-[0.3em] text-foreground"
							data-reveal="up"
						>
							<span>scroll horizontally</span>
							<Icon name="lucide:arrow-right" class="size-4" />
						</div>
					</div>
				</div>
			</Container>
		</div>

		{
			steps.map((s, i) => (
				<div
					class={`w-full md:w-screen md:h-full flex flex-col justify-center bg-background relative ${i < steps.length - 1 ? 'border-b md:border-b-0 md:border-r border-border' : ''}`}
				>
					<!-- huge ghost numeral -->
					<div
						aria-hidden="true"
						class="absolute top-1/2 -translate-y-1/2 left-2 sm:left-4 md:left-6 lg:left-12 select-none font-bold text-foreground/[0.045] text-[9rem] sm:text-[14rem] md:text-[28rem] leading-none tracking-tighter num-tabular"
					>
						{s.n}
					</div>

					<Container size="xl" class="py-14 sm:py-20 md:py-0 relative">
						<div class="grid md:grid-cols-12 gap-8 sm:gap-12 md:gap-16 items-center">
							<div class="md:col-span-6 lg:col-span-5 space-y-5 sm:space-y-6 md:space-y-10">
								<div class="flex items-center gap-4">
									<div class="text-[10px] uppercase tracking-[0.3em] text-primary">
										{s.eyebrow}
									</div>
									<div class="h-px flex-1 bg-border"></div>
									<div class="text-[10px] uppercase tracking-[0.3em] text-muted-foreground num-tabular">
										step {s.n}
									</div>
								</div>

								<h3 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold leading-[1.02] tracking-tight">
									<span data-split="word">{s.title}</span>
								</h3>

								<p
									class="text-base md:text-lg text-foreground/75 max-w-md leading-[1.55]"
									data-reveal="up"
								>
									{s.desc}
								</p>
							</div>

							<!-- Art column -->
							<div class="md:col-span-6 lg:col-span-7 md:pl-8 lg:pl-16">
								<div
									class="aspect-[5/4] max-w-md mx-auto md:mx-0 md:max-w-none border border-border rounded-2xl p-6 sm:p-8 md:p-12 bg-card relative overflow-hidden"
								>
									<!-- corner crop marks -->
									<svg
										aria-hidden="true"
										class="absolute top-3 left-3 size-3 text-border"
										viewBox="0 0 12 12"
										fill="none"
										stroke="currentColor"
									>
										<path d="M2 0 L2 4 M0 2 L4 2" />
									</svg>
									<svg
										aria-hidden="true"
										class="absolute top-3 right-3 size-3 text-border"
										viewBox="0 0 12 12"
										fill="none"
										stroke="currentColor"
									>
										<path d="M10 0 L10 4 M8 2 L12 2" />
									</svg>
									<svg
										aria-hidden="true"
										class="absolute bottom-3 left-3 size-3 text-border"
										viewBox="0 0 12 12"
										fill="none"
										stroke="currentColor"
									>
										<path d="M2 8 L2 12 M0 10 L4 10" />
									</svg>
									<svg
										aria-hidden="true"
										class="absolute bottom-3 right-3 size-3 text-border"
										viewBox="0 0 12 12"
										fill="none"
										stroke="currentColor"
									>
										<path d="M10 8 L10 12 M8 10 L12 10" />
									</svg>

									<div class="size-full flex items-center justify-center">
										{s.art === 'picker' && <LevelPicker lang={lang} class="size-full max-w-[20rem] text-foreground" />}
										{s.art === 'woven' && <WovenLesson lang={lang} class="w-full max-w-[20rem] text-foreground" />}
										{s.art === 'streak' && <StreakFlame lang={lang} class="size-full max-w-[20rem] text-foreground" />}
									</div>
								</div>
							</div>
						</div>
					</Container>
				</div>
			))
		}
	</div>
</section>
