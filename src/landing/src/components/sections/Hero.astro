---
import { Icon } from 'astro-icon/components';
import Container from '../ui/Container.astro';
import OrbitDecor from '../art/OrbitDecor.astro';
import Mark from '../art/Mark.astro';
import { defaultLang, type Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/utils';
import { DEMO_APK_URL, DEMO_APK_FILENAME } from '../../config';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section
	id="hero"
	class="relative isolate overflow-hidden min-h-[100svh] flex flex-col pt-24 sm:pt-28 md:pt-36 pb-10 sm:pb-12"
>
	<!-- vertical ticks left edge -->
	<div
		aria-hidden="true"
		class="hidden md:block absolute left-8 lg:left-12 top-32 bottom-32 w-px"
	>
		<div class="h-full ticks-y opacity-50"></div>
	</div>

	<!-- vertical chapter marker right edge -->
	<div
		aria-hidden="true"
		class="hidden md:flex absolute right-6 lg:right-10 top-1/2 -translate-y-1/2 flex-col items-center gap-3 text-[10px] uppercase tracking-[0.3em] text-muted-foreground num-tabular"
		style="writing-mode: vertical-rl;"
	>
		<span>chapter / 01</span>
		<span class="size-1 rounded-full bg-primary"></span>
		<span>introduction</span>
	</div>

	<Container size="xl" class="flex-1 flex flex-col relative">
		<!-- top meta strip -->
		<div
			class="flex items-center justify-between text-[10px] uppercase tracking-[0.25em] text-muted-foreground"
			data-reveal="up"
			data-reveal-trigger="load"
		>
			<div class="flex items-center gap-3">
				<span class="size-1 rounded-full bg-primary"></span>
				<span>/ LinVNix — vol. 01</span>
			</div>
			<div class="hidden md:flex items-center gap-4">
				<span>{t('hero.badge')}</span>
				<span class="text-foreground/40">—</span>
				<span data-scribble class="cursor-default">2026</span>
			</div>
		</div>

		<!-- Title -->
		<div class="flex-1 flex flex-col justify-center py-8 sm:py-12 md:py-16 relative">
			<!-- Decorative tonal marks scattered behind title (md+ only — too cluttered on phones) -->
			<div
				aria-hidden="true"
				class="hidden md:block absolute inset-0 pointer-events-none"
				data-mouse-track="40"
			>
				<div
					class="absolute top-[5%] left-[8%] size-10 text-primary/60"
					data-mouse-target
					data-mouse-factor="0.5"
					data-float
				>
					<Mark type="tilde" class="size-full" />
				</div>
				<div
					class="absolute top-[18%] right-[12%] size-7 text-secondary/40"
					data-mouse-target
					data-mouse-factor="1.2"
					data-float
				>
					<Mark type="acute" class="size-full" />
				</div>
				<div
					class="absolute bottom-[20%] left-[14%] size-8 text-accent/40"
					data-mouse-target
					data-mouse-factor="0.8"
					data-float
				>
					<Mark type="hook" class="size-full" />
				</div>
				<div
					class="absolute bottom-[10%] right-[8%] size-6 text-primary"
					data-mouse-target
					data-mouse-factor="1.5"
					data-float
				>
					<Mark type="dot" class="size-full" />
				</div>
				<div
					class="absolute top-[40%] right-[3%] size-9 text-secondary/50"
					data-mouse-target
					data-mouse-factor="0.7"
					data-float
				>
					<Mark type="grave" class="size-full" />
				</div>
			</div>

			<!-- Decorative orbit far right (xl only) -->
			<div
				aria-hidden="true"
				class="hidden xl:block absolute -right-24 top-1/2 -translate-y-1/2 w-[42rem] opacity-[0.18] text-primary"
				data-rotate-on-scroll="120"
			>
				<OrbitDecor class="size-full" />
			</div>

			<h1
				class="relative z-10 max-w-[20ch] lg:max-w-[24ch] font-bold leading-[0.95] tracking-[-0.04em] text-[clamp(2.25rem,6vw,5.25rem)]"
			>
				<span
					class="block text-balance [overflow-wrap:break-word]"
					data-split="word"
					data-split-trigger="load"
				>
					{t('hero.title1')}
				</span>
				<span
					class="block text-balance text-primary mt-1 md:mt-0 [overflow-wrap:break-word]"
					data-split="word"
					data-split-trigger="load"
					data-split-delay="0.18"
				>
					{t('hero.title2')}
				</span>
			</h1>

			<!-- Subtitle + CTAs row -->
			<div class="mt-8 sm:mt-12 md:mt-16 grid md:grid-cols-12 gap-6 sm:gap-8 items-end relative z-10">
				<div
					class="md:col-span-7 lg:col-span-6"
					data-reveal="up"
					data-reveal-delay="0.5"
				>
					<div class="flex items-start gap-4">
						<span
							class="text-[10px] uppercase tracking-[0.3em] text-muted-foreground mt-2 shrink-0 num-tabular"
							>§ 01</span
						>
						<p class="text-base md:text-lg text-foreground/80 leading-[1.55] max-w-xl">
							{t('hero.subtitle')}
						</p>
					</div>
				</div>

				<div
					class="md:col-span-5 lg:col-span-6 flex flex-col sm:flex-row items-stretch sm:items-center sm:justify-end gap-3"
					data-reveal="up"
					data-reveal-delay="0.6"
				>
					<div data-magnet="0.3">
						<a
							href={DEMO_APK_URL}
							download={DEMO_APK_FILENAME}
							data-magnet-inner
							class="group inline-flex items-center justify-center gap-3 h-14 px-7 rounded-full bg-primary text-primary-foreground font-semibold hover:opacity-90 transition-opacity"
						>
							<Icon name="lucide:arrow-down-to-line" class="size-4" />
							<span>{t('hero.ctaPrimary')}</span>
						</a>
					</div>
					<a
						href="#how-it-works"
						class="group inline-flex items-center justify-center gap-3 h-14 px-7 rounded-full border border-border bg-transparent text-foreground font-semibold hover:bg-muted transition-colors"
					>
						<span>{t('hero.ctaSecondary')}</span>
						<Icon
							name="lucide:arrow-down-right"
							class="size-4 transition-transform group-hover:translate-x-0.5 group-hover:translate-y-0.5"
						/>
					</a>
				</div>
			</div>
		</div>

	</Container>
</section>
