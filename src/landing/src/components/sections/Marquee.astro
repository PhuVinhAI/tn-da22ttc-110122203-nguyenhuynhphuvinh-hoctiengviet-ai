---
import Mark from '../art/Mark.astro';

const rowA = [
	'A1', 'Vocabulary', 'B2', 'Pronunciation', 'C1', 'Grammar',
	'A2', 'Listening', 'B1', 'Speaking', 'C2', 'Dialects',
];
const rowB = [
	'xin chào', 'cảm ơn', 'tạm biệt', 'phở', 'áo dài', 'sài gòn',
	'cà phê', 'ngon quá', 'em chào anh',
];
const markRotation = ['acute', 'grave', 'hook', 'tilde', 'dot', 'breve'] as const;
---

<section
	aria-hidden="true"
	class="relative border-y border-border bg-card overflow-hidden py-5 sm:py-6 md:py-8"
>
	<!-- Row 1: Vietnamese phrases, large editorial -->
	<div
		data-marquee
		data-marquee-speed="55"
		data-marquee-reactive
		class="relative mb-2"
	>
		<div
			data-marquee-track
			class="flex items-center whitespace-nowrap will-change-transform gap-6 sm:gap-8 md:gap-12 text-3xl sm:text-4xl md:text-6xl font-bold tracking-tight text-foreground"
		>
			{
				rowB.map((w, i) => {
					const mark = markRotation[i % markRotation.length];
					return (
						<span class="inline-flex items-center gap-6 md:gap-10">
							<span>{w}</span>
							<span class="size-6 md:size-7 text-primary inline-flex">
								<Mark type={mark} class="size-full" />
							</span>
						</span>
					);
				})
			}
		</div>
	</div>

	<!-- Row 2: CEFR + skill labels, mono uppercase, reverse direction -->
	<div
		data-marquee
		data-marquee-speed="80"
		data-marquee-direction="right"
		class="relative"
	>
		<div
			data-marquee-track
			class="flex items-center whitespace-nowrap will-change-transform gap-6 md:gap-10 text-xs md:text-sm uppercase tracking-[0.3em] text-muted-foreground num-tabular"
		>
			{
				rowA.map((w) => (
					<span class="inline-flex items-center gap-6 md:gap-10">
						<span>{w}</span>
						<span class="size-1 rounded-full bg-border"></span>
					</span>
				))
			}
		</div>
	</div>
</section>
