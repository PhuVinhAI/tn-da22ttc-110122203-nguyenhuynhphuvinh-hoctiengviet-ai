---
import { Icon } from 'astro-icon/components';
import Container from '../ui/Container.astro';
import Logo from '../ui/Logo.astro';
import { defaultLang, type Lang } from '../../i18n/config';
import { localizedPath, useTranslations } from '../../i18n/utils';
import { ADMIN_URL, CONTACT_URL } from '../../config';

interface Props {
	lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const base = localizedPath(lang);
const year = 2026;

const columns = [
	{
		title: t('footer.product'),
		links: [
			{ label: t('nav.features'), href: `${base}#features` },
			{ label: t('nav.howItWorks'), href: `${base}#how-it-works` },
			{ label: t('nav.pricing'), href: `${base}#pricing` },
			{ label: t('nav.faq'), href: `${base}#faq` },
		],
	},
	{
		title: t('footer.contact'),
		links: [
			{ label: t('hero.ctaPrimary'), href: `${base}#cta` },
			{ label: 'Zalo', href: CONTACT_URL, external: true },
		],
	},
];
---

<footer class="border-t border-border bg-card relative">
	<Container size="xl">
		<div class="py-12 sm:py-16 md:py-20 grid grid-cols-2 md:grid-cols-12 gap-8 sm:gap-10">
			<div class="col-span-2 md:col-span-6 space-y-5 sm:space-y-6">
				<Logo size="md" />
				<p class="text-sm text-foreground/70 max-w-sm leading-[1.6]">
					{t('footer.tagline')}
				</p>
			</div>

			{
				columns.map((col) => (
					<div class="md:col-span-3">
						<div class="text-[10px] uppercase tracking-[0.3em] text-muted-foreground">
							/ {col.title}
						</div>
						<ul class="mt-4 sm:mt-6 space-y-3">
							{col.links.map((link) => (
								<li>
									<a
										href={link.href}
										target={'external' in link && link.external ? '_blank' : undefined}
										rel={'external' in link && link.external ? 'noopener noreferrer' : undefined}
										class="link-editorial text-sm text-foreground/80 hover:text-foreground transition-colors"
									>
										{link.label}
									</a>
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>

		<div class="py-6 border-t border-border flex flex-col md:flex-row items-start md:items-center justify-between gap-3 text-[10px] uppercase tracking-[0.3em] text-muted-foreground num-tabular">
			<div class="flex items-center gap-3">
				<span class="size-1 rounded-full bg-primary"></span>
				<span>© {year} LinVNix. {t('footer.copyright')}</span>
			</div>
			<div>{t('footer.madeIn')}</div>
		</div>
	</Container>

	<a
		href={ADMIN_URL}
		target="_blank"
		rel="noopener noreferrer"
		class="group block border-t border-border bg-card hover:bg-foreground hover:text-background transition-colors duration-500"
	>
		<Container size="xl">
			<div class="py-10 sm:py-12 md:py-16 grid grid-cols-12 items-center gap-6 sm:gap-8">
				<div
					class="col-span-12 md:col-span-3 flex items-center gap-3 text-[10px] uppercase tracking-[0.3em] text-muted-foreground group-hover:text-background/60 transition-colors num-tabular"
				>
					<span
						class="size-1 rounded-full bg-primary group-hover:bg-background transition-colors"
					></span>
					<span>/ 07 — admin</span>
				</div>

				<div class="col-span-12 md:col-span-7">
					<div class="flex items-end gap-3 md:gap-5 flex-wrap">
						<span
							class="text-section font-bold leading-[0.95] tracking-[-0.035em]"
							data-split="word"
						>
							{t('footer.adminCta')}
						</span>
					</div>
					<div
						class="mt-3 text-[11px] uppercase tracking-[0.25em] text-muted-foreground group-hover:text-background/60 transition-colors num-tabular"
					>
						linvnix-admin.pages.dev
					</div>
				</div>

				<div class="col-span-12 md:col-span-2 flex md:justify-end">
					<span
						class="relative inline-flex size-14 md:size-16 items-center justify-center rounded-full border border-border group-hover:border-background/30 group-hover:bg-background group-hover:text-foreground transition-all duration-500 overflow-hidden"
					>
						<Icon
							name="lucide:arrow-up-right"
							class="size-5 md:size-6 transition-transform duration-500 ease-[cubic-bezier(0.7,0,0.2,1)] group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
						/>
					</span>
				</div>
			</div>
		</Container>
	</a>
</footer>
