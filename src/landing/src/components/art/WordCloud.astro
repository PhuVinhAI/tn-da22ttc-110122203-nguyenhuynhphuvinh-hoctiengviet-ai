---
import { defaultLang, type Lang } from '../../i18n/config';
import { useArtTranslations } from '../../i18n/art';

interface Props {
	class?: string;
	lang?: Lang;
}
const { class: className = '', lang = defaultLang } = Astro.props;
const t = useArtTranslations(lang);
---

<svg
	viewBox="0 0 280 200"
	class={className}
	aria-hidden="true"
	font-family="var(--font-sans)"
>
	<!-- Top meta row: POS + classifier badge | bookmark -->
	<g font-size="9" letter-spacing="0.18em" font-weight="600" fill="currentColor" opacity="0.6">
		<text x="14" y="22">{t('word.pos')}</text>
	</g>

	<!-- Bookmark (Yêu sách) icon top-right -->
	<g transform="translate(254 14)" fill="var(--primary)">
		<path d="M0 0 L0 14 L5 10 L10 14 L10 0 Z" />
	</g>

	<!-- Vietnamese word -->
	<g fill="currentColor">
		<text x="14" y="68" font-size="32" font-weight="700" letter-spacing="-0.025em">
			con mèo
		</text>
	</g>

	<!-- Pronunciation -->
	<g fill="currentColor" opacity="0.55" font-size="13" letter-spacing="0.02em">
		<text x="14" y="92">/kɔn mɛw˧˩/</text>
	</g>

	<!-- Translation -->
	<g fill="currentColor" font-size="14" font-weight="500" font-style="italic" opacity="0.85">
		<text x="14" y="114">{t('word.translation')}</text>
	</g>

	<!-- Divider -->
	<line x1="14" y1="130" x2="266" y2="130" stroke="currentColor" stroke-width="0.5" opacity="0.25" data-draw />

	<!-- Dialect variants section -->
	<g font-size="8" letter-spacing="0.25em" font-weight="600" fill="currentColor" opacity="0.5">
		<text x="14" y="148">{t('word.dialectN')}</text>
		<text x="100" y="148">{t('word.dialectC')}</text>
		<text x="200" y="148">{t('word.dialectS')}</text>
	</g>

	<g font-size="14" font-weight="600" fill="currentColor">
		<text x="14" y="172">con mèo</text>
		<text x="100" y="172">con méo</text>
		<text x="200" y="172">con mèo</text>
	</g>

	<!-- Decorative accent stripe on left -->
	<line x1="2" y1="14" x2="2" y2="60" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" />
</svg>
