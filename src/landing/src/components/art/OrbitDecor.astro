---
interface Props {
	class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
	viewBox="0 0 400 400"
	fill="none"
	stroke="currentColor"
	stroke-width="1"
	class={className}
	aria-hidden="true"
	data-draw
	data-draw-duration="3"
>
	<!-- nested orbit ellipses tilted -->
	<g transform="translate(200 200)">
		<ellipse rx="180" ry="80" transform="rotate(-20)" opacity="0.4" />
		<ellipse rx="140" ry="60" transform="rotate(20)" opacity="0.55" />
		<ellipse rx="100" ry="40" transform="rotate(-50)" opacity="0.7" />
	</g>

	<!-- floating sparkle dots -->
	<g fill="currentColor">
		<circle cx="320" cy="120" r="2" />
		<circle cx="80" cy="280" r="1.5" />
		<circle cx="260" cy="320" r="1" />
		<circle cx="150" cy="80" r="1.5" />
	</g>

	<!-- center cinnabar mark -->
	<circle cx="200" cy="200" r="6" fill="var(--primary)" stroke="none" />
	<circle cx="200" cy="200" r="14" stroke="var(--primary)" stroke-width="0.75" />
</svg>
