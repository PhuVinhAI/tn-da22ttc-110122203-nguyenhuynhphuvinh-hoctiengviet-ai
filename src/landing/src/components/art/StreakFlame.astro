---
import { defaultLang, type Lang } from '../../i18n/config';
import { useArtTranslations } from '../../i18n/art';

interface Props {
	class?: string;
	lang?: Lang;
}
const { class: className = '', lang = defaultLang } = Astro.props;
const t = useArtTranslations(lang);

const goals = [
	{ label: t('streak.exercises'), current: 8, max: 10, done: false },
	{ label: t('streak.simulations'), current: 3, max: 3, done: true },
	{ label: t('streak.lessons'), current: 2, max: 5, done: false },
];

const barWidth = 108;
---

<svg
	viewBox="0 0 280 200"
	class={className}
	aria-hidden="true"
	font-family="var(--font-sans)"
>
	<!-- Header -->
	<g font-size="8" letter-spacing="0.22em" font-weight="600" fill="currentColor" opacity="0.55">
		<text x="14" y="22">{t('streak.today')}</text>
	</g>

	<!-- Goals list -->
	{
		goals.map((g, i) => {
			const y = 42 + i * 30;
			const pct = g.current / g.max;
			return (
				<g>
					{/* checkbox */}
					<rect
						x="14"
						y={y}
						width="12"
						height="12"
						rx="3"
						fill={g.done ? 'var(--primary)' : 'none'}
						stroke="currentColor"
						stroke-width="1"
						opacity={g.done ? '1' : '0.5'}
					/>
					{g.done && (
						<path
							d={`M ${17} ${y + 6} L ${19} ${y + 8.5} L ${23} ${y + 4.5}`}
							stroke="var(--primary-foreground)"
							stroke-width="1.5"
							fill="none"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					)}
					{/* label */}
					<text
						x="34"
						y={y + 10}
						font-size="9"
						letter-spacing="0.2em"
						font-weight="600"
						fill="currentColor"
					>
						{g.label}
					</text>
					{/* bar track */}
					<rect x="120" y={y + 4} width={barWidth} height="4" rx="2" fill="currentColor" opacity="0.12" />
					{/* bar fill */}
					<rect
						x="120"
						y={y + 4}
						width={barWidth * pct}
						height="4"
						rx="2"
						fill={g.done ? 'var(--primary)' : 'currentColor'}
					/>
					{/* count */}
					<text
						x="258"
						y={y + 10}
						font-size="9"
						font-weight="700"
						fill="currentColor"
						text-anchor="end"
					>
						{g.current}/{g.max}
					</text>
				</g>
			);
		})
	}

	<!-- Divider -->
	<line x1="14" y1="138" x2="266" y2="138" stroke="currentColor" stroke-width="0.5" opacity="0.25" data-draw />

	<!-- Streak section -->
	<g font-size="8" letter-spacing="0.22em" font-weight="600" fill="currentColor" opacity="0.55">
		<text x="14" y="160">{t('streak.streak')}</text>
	</g>
	<g font-size="9" font-weight="500" fill="currentColor" opacity="0.7">
		<text x="14" y="185">{t('streak.longest')}</text>
	</g>

	<!-- Big streak number -->
	<g transform="translate(266 188)">
		<text
			font-size="46"
			font-weight="800"
			fill="currentColor"
			letter-spacing="-0.04em"
			text-anchor="end"
		>
			47<tspan font-size="11" fill="currentColor" opacity="0.55" font-weight="600" letter-spacing="0.15em">{t('streak.dayAbbr')}</tspan>
		</text>
	</g>

	<!-- Cinnabar dot accent next to streak -->
	<circle cx="270" cy="156" r="3" fill="var(--primary)" />
</svg>
