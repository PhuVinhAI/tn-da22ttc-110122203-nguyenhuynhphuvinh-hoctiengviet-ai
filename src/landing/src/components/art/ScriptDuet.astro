---
import { defaultLang, type Lang } from '../../i18n/config';
import { useArtTranslations } from '../../i18n/art';

interface Props {
	class?: string;
	lang?: Lang;
}
const { class: className = '', lang = defaultLang } = Astro.props;
const t = useArtTranslations(lang);
---

<svg
	viewBox="0 0 280 200"
	class={className}
	aria-hidden="true"
	font-family="var(--font-sans)"
>
	<!-- RULE label -->
	<g font-size="9" letter-spacing="0.25em" font-weight="600" fill="currentColor" opacity="0.55">
		<text x="14" y="22">{t('duet.title')}</text>
	</g>

	<!-- Vietnamese sentence -->
	<text x="14" y="56" font-size="18" font-weight="700" letter-spacing="-0.015em">
		<tspan fill="currentColor">Em uống cà phê </tspan><tspan
			fill="var(--primary)"
			font-weight="800"
		>không?</tspan>
	</text>

	<!-- VI label -->
	<g font-size="8" letter-spacing="0.25em" font-weight="500" fill="currentColor" opacity="0.4">
		<text x="14" y="74">{t('duet.vnLabel')}</text>
	</g>

	<!-- Arrow connector -->
	<g stroke="currentColor" stroke-width="1" fill="none" opacity="0.4" data-draw>
		<line x1="20" y1="92" x2="20" y2="108" stroke-linecap="round" />
		<path d="M16 104 L20 110 L24 104" stroke-linecap="round" />
	</g>

	<!-- English sentence -->
	<text x="14" y="136" font-size="18" font-weight="700" letter-spacing="-0.015em">
		<tspan fill="var(--primary)" font-weight="800">Do</tspan><tspan
			fill="currentColor"
		> you drink coffee?</tspan>
	</text>

	<!-- EN label -->
	<g font-size="8" letter-spacing="0.25em" font-weight="500" fill="currentColor" opacity="0.4">
		<text x="14" y="154">{t('duet.enLabel')}</text>
	</g>

	<!-- Divider -->
	<line x1="14" y1="166" x2="266" y2="166" stroke="currentColor" stroke-width="0.5" opacity="0.25" data-draw />

	<!-- Pattern abstraction -->
	<text x="14" y="184" font-size="10" font-weight="500" letter-spacing="0.02em">
		<tspan fill="currentColor" fill-opacity="0.6">[S] + [V] + [O] + </tspan><tspan
			fill="var(--primary)"
			font-weight="700"
		>không?</tspan>
	</text>
</svg>
