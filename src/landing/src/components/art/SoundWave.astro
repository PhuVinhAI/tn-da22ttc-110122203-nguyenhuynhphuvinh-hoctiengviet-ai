---
import { defaultLang, type Lang } from '../../i18n/config';
import { useArtTranslations } from '../../i18n/art';

interface Props {
	class?: string;
	lang?: Lang;
}
const { class: className = '', lang = defaultLang } = Astro.props;
const t = useArtTranslations(lang);
---

<svg
	viewBox="0 0 280 200"
	class={className}
	aria-hidden="true"
	font-family="var(--font-sans)"
>
	<!-- Header -->
	<g font-size="8" letter-spacing="0.22em" font-weight="600" fill="currentColor" opacity="0.55">
		<text x="14" y="18">{t('tutor.title')}</text>
	</g>
	<g
		font-size="7"
		letter-spacing="0.22em"
		font-weight="600"
		fill="currentColor"
		opacity="0.4"
		text-anchor="end"
	>
		<text x="266" y="18">LIVE</text>
	</g>
	<line
		x1="14"
		y1="28"
		x2="266"
		y2="28"
		stroke="currentColor"
		stroke-width="0.5"
		opacity="0.2"
		data-draw
	/>

	<!-- Single card: top = screen, bottom = AI hint -->
	<g transform="translate(14, 40)">
		<rect
			width="252"
			height="124"
			rx="10"
			fill="none"
			stroke="currentColor"
			stroke-width="1"
			opacity="0.5"
		/>

		<!-- Screen section -->
		<g font-size="7" letter-spacing="0.22em" font-weight="600" fill="currentColor" opacity="0.5">
			<text x="14" y="20">{t('tutor.lessonMeta')}</text>
		</g>

		<text
			x="14"
			y="50"
			font-size="14"
			font-weight="700"
			fill="currentColor"
			letter-spacing="-0.01em"
		>Bạn khoẻ ___ ?</text>

		<g
			font-size="8"
			letter-spacing="0.18em"
			font-weight="600"
			fill="currentColor"
			opacity="0.45"
		>
			<text x="14" y="64">{t('tutor.typing')}</text>
		</g>

		<!-- Inner divider -->
		<line
			x1="0"
			y1="78"
			x2="252"
			y2="78"
			stroke="currentColor"
			stroke-width="0.5"
			opacity="0.2"
		/>

		<!-- AI hint strip -->
		<rect
			x="14"
			y="92"
			width="22"
			height="14"
			rx="4"
			fill="currentColor"
		/>
		<text
			x="25"
			y="103"
			font-size="8"
			font-weight="700"
			fill="var(--background)"
			text-anchor="middle"
			letter-spacing="0.1em"
		>AI</text>

		<text
			x="44"
			y="98"
			font-size="7"
			letter-spacing="0.22em"
			font-weight="600"
			fill="var(--primary)"
		>{t('tutor.hint')}</text>

		<text
			x="44"
			y="111"
			font-size="10"
			font-weight="500"
			fill="currentColor"
			opacity="0.85"
		>{t('tutor.hintText')}</text>
	</g>

	<!-- Footer: camera (photo discovery) -->
	<g transform="translate(14, 184)" stroke="currentColor" fill="none" opacity="0.65" stroke-linejoin="round">
		<rect x="0" y="-6" width="16" height="12" rx="2" stroke-width="1" />
		<path d="M3 -6 L5 -9 L11 -9 L13 -6" stroke-width="1" />
		<circle cx="8" cy="0" r="3" stroke-width="1" />
	</g>
	<text
		x="36"
		y="188"
		font-size="8"
		letter-spacing="0.22em"
		font-weight="600"
		fill="currentColor"
		opacity="0.6"
	>{t('tutor.camera')}</text>
	<circle cx="262" cy="185" r="2.5" fill="var(--primary)" />
</svg>
