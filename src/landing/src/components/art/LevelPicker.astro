---
import { defaultLang, type Lang } from '../../i18n/config';
import { useArtTranslations } from '../../i18n/art';

interface Props {
	class?: string;
	lang?: Lang;
}
const { class: className = '', lang = defaultLang } = Astro.props;
const t = useArtTranslations(lang);

const levels = [
	{ code: 'A1', state: 'done' },
	{ code: 'A2', state: 'done' },
	{ code: 'B1', state: 'active' },
	{ code: 'B2', state: 'locked' },
	{ code: 'C1', state: 'locked' },
	{ code: 'C2', state: 'locked' },
];

const cardW = 60;
const cardH = 56;
const gap = 8;
const startX = 22;
const startY = 58;
---

<svg
	viewBox="0 0 240 240"
	class={className}
	aria-hidden="true"
	font-family="var(--font-sans)"
>
	<!-- Header -->
	<g font-size="8" letter-spacing="0.22em" font-weight="600" fill="currentColor" opacity="0.55">
		<text x="14" y="18">{t('picker.title')}</text>
	</g>
	<g
		font-size="7"
		letter-spacing="0.22em"
		font-weight="600"
		fill="currentColor"
		opacity="0.4"
		text-anchor="end"
	>
		<text x="226" y="18">{t('picker.tiers')}</text>
	</g>

	<!-- Divider + placement progress -->
	<line
		x1="14"
		y1="28"
		x2="226"
		y2="28"
		stroke="currentColor"
		stroke-width="0.5"
		opacity="0.2"
		data-draw
	/>
	<g font-size="7" letter-spacing="0.2em" font-weight="500" fill="currentColor" opacity="0.5">
		<text x="14" y="44">{t('picker.quick')}</text>
	</g>
	<g transform="translate(196, 41)">
		<circle cx="0" cy="0" r="2" fill="var(--primary)" />
		<circle cx="7" cy="0" r="2" fill="var(--primary)" />
		<circle cx="14" cy="0" r="2" fill="var(--primary)" opacity="0.4" />
		<circle cx="21" cy="0" r="2" fill="currentColor" opacity="0.18" />
		<circle cx="28" cy="0" r="2" fill="currentColor" opacity="0.18" />
	</g>

	{
		levels.map((l, i) => {
			const col = i % 3;
			const row = Math.floor(i / 3);
			const x = startX + col * (cardW + gap);
			const y = startY + row * (cardH + gap);
			const cx = x + cardW / 2;
			const cy = y + cardH / 2;
			const isDone = l.state === 'done';
			const isActive = l.state === 'active';
			const isLocked = l.state === 'locked';

			return (
				<g>
					{/* Card */}
					<rect
						x={x}
						y={y}
						width={cardW}
						height={cardH}
						rx="8"
						fill={isActive ? 'var(--primary)' : 'transparent'}
						stroke={isActive ? 'transparent' : 'currentColor'}
						stroke-width="1"
						opacity={isLocked ? '0.3' : isDone ? '0.55' : '1'}
					/>

					{/* Done state */}
					{isDone && (
						<g transform={`translate(${x + cardW - 16}, ${y + 8})`} opacity="0.75">
							<path
								d="M0 4 L3 7 L9 0"
								stroke="currentColor"
								stroke-width="1.4"
								fill="none"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</g>
					)}

					{/* Active pulse */}
					{isActive && (
						<circle cx={x + cardW - 10} cy={y + 10} r="3" fill="var(--primary-foreground)">
							<animate attributeName="r" values="3;5;3" dur="2s" repeatCount="indefinite" />
							<animate
								attributeName="opacity"
								values="0.95;0.35;0.95"
								dur="2s"
								repeatCount="indefinite"
							/>
						</circle>
					)}

					{/* Locked dots */}
					{isLocked && (
						<g transform={`translate(${x + cardW - 16}, ${y + 8})`} opacity="0.5">
							<circle cx="0" cy="2" r="0.9" fill="currentColor" />
							<circle cx="4" cy="2" r="0.9" fill="currentColor" />
							<circle cx="8" cy="2" r="0.9" fill="currentColor" />
						</g>
					)}

					{/* Level code */}
					<text
						x={cx}
						y={cy + 4}
						font-size="18"
						font-weight="700"
						fill={isActive ? 'var(--primary-foreground)' : 'currentColor'}
						text-anchor="middle"
						letter-spacing="0.04em"
						opacity={isLocked ? '0.75' : '1'}
					>
						{l.code}
					</text>

					{/* Active label */}
					{isActive && (
						<text
							x={cx}
							y={y + cardH - 8}
							font-size="6"
							letter-spacing="0.3em"
							font-weight="700"
							fill="var(--primary-foreground)"
							text-anchor="middle"
							opacity="0.85"
						>
							{t('picker.selected')}
						</text>
					)}
				</g>
			);
		})
	}

	<!-- Footer rule + meta -->
	<line
		x1="14"
		y1="200"
		x2="226"
		y2="200"
		stroke="currentColor"
		stroke-width="0.5"
		opacity="0.25"
		data-draw
	/>
	<g font-size="8" letter-spacing="0.22em" font-weight="600" fill="currentColor" opacity="0.6">
		<text x="14" y="216">{t('picker.autoUnlock')}</text>
	</g>
	<circle cx="222" cy="213" r="2.5" fill="var(--primary)" />
</svg>
