---
import { defaultLang, type Lang } from '../../i18n/config';
import { useArtTranslations } from '../../i18n/art';

interface Props {
	class?: string;
	lang?: Lang;
}
const { class: className = '', lang = defaultLang } = Astro.props;
const t = useArtTranslations(lang);
---

<svg
	viewBox="0 0 280 220"
	class={className}
	aria-hidden="true"
	font-family="var(--font-sans)"
>
	<!-- Header -->
	<g font-size="8" letter-spacing="0.22em" font-weight="600" fill="currentColor" opacity="0.55">
		<text x="14" y="18">{t('role.title')}</text>
	</g>
	<g
		font-size="7"
		letter-spacing="0.22em"
		font-weight="600"
		fill="currentColor"
		opacity="0.4"
		text-anchor="end"
	>
		<text x="266" y="18">{t('role.difficulty')}</text>
	</g>
	<line
		x1="14"
		y1="28"
		x2="266"
		y2="28"
		stroke="currentColor"
		stroke-width="0.5"
		opacity="0.2"
		data-draw
	/>

	<!-- Scenario meta -->
	<circle cx="18" cy="44" r="2.5" fill="var(--primary)" />
	<g font-size="8" letter-spacing="0.22em" font-weight="600" fill="currentColor">
		<text x="26" y="47">CHỢ RAU · SÀI GÒN</text>
	</g>

	<!-- NPC tag + line -->
	<rect x="14" y="62" width="28" height="14" rx="4" fill="currentColor" />
	<text
		x="28"
		y="72"
		font-size="7"
		font-weight="700"
		fill="var(--background)"
		text-anchor="middle"
		letter-spacing="0.15em"
	>NPC</text>
	<text x="50" y="72" font-size="10" font-weight="500" fill="currentColor">
		Chào em! Em mua gì?
	</text>

	<!-- BẠN tag + line -->
	<rect
		x="14"
		y="86"
		width="28"
		height="14"
		rx="4"
		fill="none"
		stroke="currentColor"
		stroke-width="1"
	/>
	<text
		x="28"
		y="96"
		font-size="7"
		font-weight="700"
		fill="currentColor"
		text-anchor="middle"
		letter-spacing="0.1em"
	>{t('role.you')}</text>
	<text x="50" y="96" font-size="10" font-weight="500" fill="currentColor">
		<tspan>Cho cháu một ký rau </tspan><tspan
			fill="var(--destructive)"
			text-decoration="underline"
			text-decoration-style="wavy"
		>muong</tspan><tspan> ạ</tspan>
	</text>

	<!-- Correction hint -->
	<text
		x="50"
		y="114"
		font-size="8"
		font-weight="500"
		fill="var(--destructive)"
		letter-spacing="0.02em"
	>
		<tspan>↳ </tspan><tspan font-weight="700" letter-spacing="0.2em">{t('role.aiFix')} </tspan><tspan>muong → muống ({t('role.toneNote')})</tspan>
	</text>

	<!-- Divider -->
	<line
		x1="14"
		y1="132"
		x2="266"
		y2="132"
		stroke="currentColor"
		stroke-width="0.5"
		opacity="0.25"
		data-draw
	/>

	<!-- Score panel -->
	<g font-size="8" letter-spacing="0.22em" font-weight="600" fill="currentColor" opacity="0.55">
		<text x="14" y="152">{t('role.score')}</text>
	</g>

	<!-- Vertical separator -->
	<line x1="160" y1="158" x2="160" y2="198" stroke="currentColor" stroke-width="0.5" opacity="0.2" />

	<!-- Rubric row 1 -->
	<text
		x="14"
		y="174"
		font-size="8"
		letter-spacing="0.18em"
		font-weight="600"
		fill="currentColor"
		opacity="0.7"
	>{t('role.vocab')}</text>
	<text
		x="150"
		y="174"
		font-size="12"
		font-weight="700"
		fill="currentColor"
		text-anchor="end"
		letter-spacing="-0.01em"
	>45<tspan font-size="9" fill-opacity="0.55">/50</tspan></text>

	<!-- Rubric row 2 -->
	<text
		x="14"
		y="194"
		font-size="8"
		letter-spacing="0.18em"
		font-weight="600"
		fill="currentColor"
		opacity="0.7"
	>{t('role.grammar')}</text>
	<text
		x="150"
		y="194"
		font-size="12"
		font-weight="700"
		fill="currentColor"
		text-anchor="end"
		letter-spacing="-0.01em"
	>42<tspan font-size="9" fill-opacity="0.55">/50</tspan></text>

	<!-- Big final score -->
	<text
		x="262"
		y="192"
		font-size="36"
		font-weight="800"
		fill="currentColor"
		letter-spacing="-0.04em"
		text-anchor="end"
	>87<tspan
			font-size="13"
			fill="currentColor"
			fill-opacity="0.55"
			font-weight="600"
			letter-spacing="0.05em"
		>/100</tspan></text>
</svg>
