<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Dev build: allow cleartext HTTP so the app can reach a local backend
         (localhost, emulator host 10.0.2.2, or a LAN dev server like 192.168.x.x).
         Production builds should serve media/API over HTTPS. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
