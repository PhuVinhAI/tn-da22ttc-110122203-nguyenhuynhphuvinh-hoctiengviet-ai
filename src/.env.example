# ============================================================================
# Root .env — ONLY for `bun run db:up` (docker-compose.yml) from the repo root.
#
# This is OPTIONAL: every variable below has a default in docker-compose.yml
# (`${VAR:-default}`), so `bun run db:up` works without this file.
#
# This is NOT the backend config. For the NestJS API, copy the canonical,
# complete template instead: backend/.env.example -> backend/.env
# (it has JWT, Redis, Mail, Google OAuth, all GENAI_* / AI_* settings).
# ============================================================================

# Database (docker-compose postgres:16) — read by docker-compose.yml
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=linvnix

# Backend container port + mode — read by docker-compose.yml (backend service)
PORT=3000
NODE_ENV=development
